{
  "name": "@chriscamp/sf-data-cloud-mcp",
  "version": "0.1.3",
  "description": "MCP server for Salesforce Data Cloud operations",
  "type": "module",
  "bin": {
    "sf-data-cloud-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "bash -c 'npm run lint'"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "salesforce",
    "data-cloud",
    "ai"
  ],
  "author": "Chris Camp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChrisCampTN/sf-data-cloud-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
